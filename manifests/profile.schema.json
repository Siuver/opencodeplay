{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/opencode-bootstrap/profile.schema.json",
  "title": "Setup Profile",
  "type": "object",
  "required": ["schema_version", "id", "description", "tools", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "description": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["windows", "wsl", "linux", "macos", "any"]
      },
      "default": ["any"]
    },
    "network": {
      "type": "string",
      "enum": ["required", "optional", "forbidden"],
      "default": "optional"
    },
    "tools": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "manifest_refs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "manual_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
