{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/opencode-bootstrap/capabilities.schema.json",
  "title": "Capability Manifest",
  "type": "object",
  "required": ["schema_version", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "$defs": {
    "automation": {
      "type": "string",
      "enum": ["auto-safe", "auto-with-approval", "manual-required", "unsupported"]
    },
    "capability": {
      "type": "object",
      "required": ["id", "description", "enabled", "automation", "manifests", "requires"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "description": { "type": "string" },
        "enabled": { "type": "boolean" },
        "automation": { "$ref": "#/$defs/automation" },
        "manifests": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "manual_steps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
